{
  "name": "sanity-plugin-seo-analyser",
  "version": "0.1.2",
  "description": "A Yoast-style SEO analyser view for Sanity Studio v3+ — SEO, Readability, and Social tabs with full Portable Text support.",
  "keywords": [
    "sanity",
    "sanity-plugin",
    "seo",
    "yoast",
    "portable-text",
    "readability"
  ],
  "license": "MIT",
  "author": "Khubaib Ahmad",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "browserslist": "extends @sanity/browserslist-config",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "pkg-utils build --clean",
    "build:watch": "pkg-utils watch",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sanity/image-url": "^2.1.1"
  },
  "devDependencies": {
    "@sanity/browserslist-config": "^1.0.5",
    "@sanity/pkg-utils": "^7.0.0",
    "@types/react": "^19.0.0",
    "sanity": "^3.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "sanity": "^3.0.0 || ^4.0.0 || ^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
